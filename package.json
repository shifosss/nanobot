{
  "name": "nanobot",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "db:sample:load:local": "node scripts/db/load-sample-data.mjs --target=local",
    "db:sample:verify:local": "node scripts/db/verify-db-scenarios.mjs --target=local",
    "db:sample:cleanup:local": "node scripts/db/cleanup-sample-data.mjs --target=local",
    "db:sample:cycle:local": "node scripts/db/load-sample-data.mjs --target=local && node scripts/db/verify-db-scenarios.mjs --target=local && node scripts/db/cleanup-sample-data.mjs --target=local",
    "db:sample:load:hosted": "node scripts/db/load-sample-data.mjs --target=hosted",
    "db:sample:verify:hosted": "node scripts/db/verify-db-scenarios.mjs --target=hosted",
    "db:sample:cleanup:hosted": "node scripts/db/cleanup-sample-data.mjs --target=hosted",
    "db:sample:cycle:hosted": "node scripts/db/load-sample-data.mjs --target=hosted && node scripts/db/verify-db-scenarios.mjs --target=hosted && node scripts/db/cleanup-sample-data.mjs --target=hosted",
    "db:demo:load:hosted": "node scripts/db/load-demo-account-data.mjs --target=hosted",
    "db:demo:verify:hosted": "node scripts/db/verify-demo-account-data.mjs --target=hosted",
    "db:demo:cleanup:hosted": "node scripts/db/cleanup-demo-account-data.mjs --target=hosted",
    "db:demo:cycle:hosted": "node scripts/db/load-demo-account-data.mjs --target=hosted && node scripts/db/verify-demo-account-data.mjs --target=hosted"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "^7.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.28.0",
    "vite": "^6.2.1"
  },
  "private": true
}
